{
  "permissions": {
    "allow": [
      "Bash(xargs:*)",
      "Bash(ls:*)",
      "Bash(find:*)",
      "Bash(npx vue-tsc:*)",
      "Bash(npx vite build:*)",
      "Bash(npm run dev:*)",
      "Bash(grep:*)",
      "Bash(node -e:*)",
      "Bash(php -r:*)",
      "Bash(composer require:*)",
      "Bash(test:*)",
      "Bash(git -C /home/nehemuel/rentacar-modern status --short)",
      "Bash(git -C /home/nehemuel/rentacar-modern ls-files)",
      "Bash(git -C /home/nehemuel/rentacar-modern ls-files:*)",
      "Bash(git -C /home/nehemuel/rentacar-modern log --oneline -20)",
      "Bash(git -C /home/nehemuel/rentacar-modern check-ignore frontend/node_modules backend/vendor)",
      "Bash(git -C /home/nehemuel/rentacar-modern status)",
      "Bash(docker-compose ps:*)",
      "Bash(curl:*)",
      "Bash(docker exec:*)",
      "Bash(python3:*)",
      "Bash(wc:*)",
      "Bash(docker restart:*)",
      "Bash(docker compose exec:*)",
      "Bash(php:*)",
      "WebFetch(domain:docs.sms-gate.app)",
      "WebFetch(domain:capcom6.github.io)",
      "WebFetch(domain:github.com)",
      "Bash(docker compose up:*)",
      "Bash(__NEW_LINE_56c162677bf4906a__ echo \"=== Dashboard Stats ===\")",
      "Bash(__NEW_LINE_d5408813448b296c__ echo -e \"\\\\n=== Billing Plans ===\")",
      "Bash(__NEW_LINE_1fce1c7df34773ca__ echo -e \"\\\\n=== Test SMS \\(should fail - no credits\\) ===\")",
      "WebFetch(domain:developers.messagebird.com)",
      "WebFetch(domain:apibcrd.bancentral.gov.do)",
      "Bash(npx tsc:*)",
      "Bash(head -20 grep -n \"balance_amount\\\\|payment_method\" /home/nehemuel/rentacar-modern/frontend/src/views/bookings/components/SidebarOverviewTab.vue)"
    ],
    "defaultMode": "bypassPermissions"
  },
  "statusLine": {
    "type": "command",
    "command": "bash -c 'if [ \"$CLAUDE_NO_HUD\" = \"1\" ]; then exit 0; fi; plugin_dir=$(ls -d \"${CLAUDE_CONFIG_DIR:-$HOME/.claude}\"/plugins/cache/claude-hud/claude-hud/*/ 2>/dev/null | awk -F/ '\"'\"'{ print $(NF-1) \"\\t\" $0 }'\"'\"' | sort -t. -k1,1n -k2,2n -k3,3n -k4,4n | tail -1 | cut -f2-); exec \"/usr/local/bin/node\" \"${plugin_dir}dist/index.js\"'"
  },
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "playwright@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "commit-commands@claude-plugins-official": true,
    "figma@claude-plugins-official": true,
    "claude-code-setup@claude-plugins-official": true,
    "greptile@claude-plugins-official": true,
    "php-lsp@claude-plugins-official": true,
    "laravel-boost@claude-plugins-official": true,
    "clangd-lsp@claude-plugins-official": true,
    "coderabbit@claude-plugins-official": true,
    "frontend-design@claude-code-plugins": true,
    "security-guidance@claude-code-plugins": true,
    "Notion@claude-plugins-official": true,
    "claude-hud@claude-hud": true
  },
  "language": "Español",
  "autoMemoryEnabled": true,
  "skipDangerousModePermissionPrompt": true,
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/rtk-rewrite.sh"
          }
        ]
      }
    ]
  }
}
