#!/usr/bin/env bash
set -euo pipefail

# --- agents: tmux agent-team Claude launcher ---
# Usage: agents [directory]
# Lanza Claude con agent teams en paneles tmux.
# Temporalmente desactiva agent:pm para que Claude pueda crear teams.
# Panel principal más ancho + HUD solo en panel principal.

dir="${1:-$PWD}"

if [[ ! -d "$dir" ]]; then
    echo "Error: '$dir' no es un directorio válido" >&2
    exit 1
fi

dir="$(cd "$dir" && pwd)"

session="agents-$(date +%Y-%m-%d)"
if tmux has-session -t "=$session" 2>/dev/null; then
    session="agents-$(date +%Y-%m-%d_%H-%M-%S)"
fi

if ! command -v tmux &>/dev/null; then
    echo "Error: tmux no está instalado" >&2
    exit 1
fi

# --- Manejar conflicto agent:pm ---
SETTINGS_FILE="$dir/.claude/settings.local.json"
SETTINGS_BAK="$dir/.claude/settings.local.json.teams-bak"
NEEDS_RESTORE=false

if [[ -f "$SETTINGS_FILE" ]] && grep -q '"agent"' "$SETTINGS_FILE"; then
    cp "$SETTINGS_FILE" "$SETTINGS_BAK"
    NEEDS_RESTORE=true
    if command -v jq &>/dev/null; then
        jq 'del(.agent)' "$SETTINGS_BAK" > "$SETTINGS_FILE"
    else
        sed '/"agent"/d' "$SETTINGS_BAK" > "$SETTINGS_FILE"
    fi
fi

# Restaurar settings al salir (ctrl+c, exit, etc)
cleanup() {
    if [[ "$NEEDS_RESTORE" == true ]] && [[ -f "$SETTINGS_BAK" ]]; then
        mv "$SETTINGS_BAK" "$SETTINGS_FILE"
    fi
}
trap cleanup EXIT

# Prompt para crear el team automáticamente
read -r -d '' TEAM_PROMPT << 'EOF' || true
Crea un agent team AHORA con 5 teammates: prompt-engineer (Opus), dba (Opus), devops (Sonnet), codex-agent (Sonnet), gemini-agent (Sonnet). No investigues ni leas archivos primero. Solo crea el team y espera mis instrucciones.
EOF

pane=$(tmux new-session -d -s "$session" -c "$dir" -PF '#{pane_id}')

# Hook: re-aplica layout main-vertical con lead al 75% cada vez que se crea un pane
# Esto evita que el panel del lead se comprima cuando se agregan/quitan teammates
tmux set-hook -t "$session" after-split-window \
    "run-shell 'tmux select-pane -t ${session}:0.0 && tmux select-layout -t ${session} main-vertical && tmux resize-pane -t ${session}:0.0 -x 75% || true'"

# Solo el panel principal tiene HUD (teammates no tendrán CLAUDE_NO_HUD=0)
# CLAUDE_NO_HUD no está seteado aquí → HUD activo en este panel
# Los teammates se spawnean en panes nuevos donde seteamos CLAUDE_NO_HUD=1
tmux set-environment -t "$session" CLAUDE_NO_HUD "1"
tmux send-keys -t "$pane" 'export CLAUDE_NO_HUD=0 && TMPDIR=~/.cache/tmp claude --teammate-mode tmux --dangerously-skip-permissions --effort max' Enter

# Esperar a que Claude esté listo, luego enviar prompt del team
# y después redimensionar el panel principal
(
    sleep 8
    tmux send-keys -t "$pane" "$TEAM_PROMPT" Enter

    # Esperar a que se creen los teammates, luego reorganizar layout
    # Lead ocupa todo el alto izquierdo (75%), teammates apilados a la derecha (25%)
    sleep 30
    tmux select-pane -t "$session:0.0"
    tmux select-layout -t "$session" main-vertical
    tmux resize-pane -t "$session:0.0" -x '75%'
) &

exec tmux attach-session -t "$session"
