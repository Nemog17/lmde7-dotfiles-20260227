#!/usr/bin/env bash
set -euo pipefail

# --- agents: tmux agent-team Claude launcher ---
# Usage: agents [directory]
# Lanza Claude con agent teams en paneles tmux.
# Temporalmente desactiva agent:pm para que Claude pueda crear teams.
# Panel principal más ancho + HUD solo en panel principal.

dir="${1:-$PWD}"

if [[ ! -d "$dir" ]]; then
    echo "Error: '$dir' no es un directorio válido" >&2
    exit 1
fi

dir="$(cd "$dir" && pwd)"

session="agents-$(date +%Y-%m-%d)"
if tmux has-session -t "=$session" 2>/dev/null; then
    session="agents-$(date +%Y-%m-%d_%H-%M-%S)"
fi

if ! command -v tmux &>/dev/null; then
    echo "Error: tmux no está instalado" >&2
    exit 1
fi

# --- Manejar conflicto agent:pm ---
SETTINGS_FILE="$dir/.claude/settings.local.json"
SETTINGS_BAK="$dir/.claude/settings.local.json.teams-bak"
NEEDS_RESTORE=false

if [[ -f "$SETTINGS_FILE" ]] && grep -q '"agent"' "$SETTINGS_FILE"; then
    cp "$SETTINGS_FILE" "$SETTINGS_BAK"
    NEEDS_RESTORE=true
    if command -v jq &>/dev/null; then
        jq 'del(.agent)' "$SETTINGS_BAK" > "$SETTINGS_FILE"
    else
        sed '/"agent"/d' "$SETTINGS_BAK" > "$SETTINGS_FILE"
    fi
fi

# Restaurar settings al salir (ctrl+c, exit, etc)
cleanup() {
    if [[ "$NEEDS_RESTORE" == true ]] && [[ -f "$SETTINGS_BAK" ]]; then
        mv "$SETTINGS_BAK" "$SETTINGS_FILE"
    fi
}
trap cleanup EXIT

# Prompt para crear el team automáticamente
read -r -d '' TEAM_PROMPT << 'EOF' || true
Crea un agent team para este proyecto con estos 4 teammates:

1. **Frontend** (Opus): Ingeniero frontend senior. Vue.js 3, Tailwind CSS, shadcn/Basecoat, mobile-first. Usa skills frontend-design y emil-design-eng para diseño de alta calidad. Usa shadcn MCP y Context7 (OpenUI, Vue, Tailwind). Diseña PRIMERO para móvil, luego adapta a desktop.

2. **Backend** (Sonnet): Ingeniero backend senior. Laravel 12, GraphQL (Lighthouse), PostgreSQL (Neon), Sanctum, Spatie. Actions como lógica de negocio. Usa Laravel Boost MCP, Neon MCP y Context7 (Laravel, Lighthouse).

3. **DBA** (Sonnet): DBA senior. PostgreSQL, multi-tenancy (BelongsToTenant), migraciones, indexes, EXCLUDE constraints, pg_trgm. Usa Neon MCP para queries, schemas y branches. Migraciones destructivas requieren confirmación del usuario.

4. **DevOps** (Sonnet): Ingeniero DevOps senior. Cloudflare (Workers, Containers, Pages, R2), GitHub Actions, Docker, Neon branches. NUNCA tocar producción sin confirmar. Usa gh CLI, wrangler CLI.

## Tu Rol como Lead

Eres un Staff Engineer y prompt engineer. Tu trabajo es:
- Usar el skill superpowers:brainstorming ANTES de asignar tareas (explorar intención, requisitos, diseño)
- Redactar prompts profesionales tipo PRD/spec para cada teammate: Contexto → Problema → Solución → Criterios de Aceptación
- Usar lenguaje descriptivo y humano, luego detalle técnico preciso

## Agentes Externos (via @swarmify/agents-mcp)

Tienes acceso a Codex CLI y Gemini CLI. Úsalos PROACTIVAMENTE sin pedir permiso:

- **Codex CLI**: Consultor técnico. Úsalo para preguntas difíciles de backend/DB, debugging, testing, code review, solución de bugs. Antes de que el equipo implemente algo complejo, consulta a Codex para obtener la mejor solución.
- **Gemini CLI**: Diseñador. Úsalo para crear prototipos visuales y briefs de diseño ANTES de implementar. Dale briefs descriptivos (no código). Luego el equipo implementa 10x mejor basándose en el prototipo.

## Reglas

- Si el usuario escribe @pm, despacha el PM Agent tradicional como subagente (subagent_type="pm")
- Usa skills: brainstorming, frontend-design, Context7 MCP, Figma MCP
- Usa subagentes (herramienta Agent) para tareas complejas y extensas que requieran investigación profunda o implementación larga
- Los teammates pueden lanzar subagentes para dividir su trabajo en paralelo
- Explica todo en español simple al usuario
- NO despachar PM automáticamente — solo si el usuario escribe @pm (y solo esa vez)
- Espera las instrucciones del usuario antes de asignar tareas
EOF

pane=$(tmux new-session -d -s "$session" -c "$dir" -PF '#{pane_id}')

# Solo el panel principal tiene HUD (teammates no tendrán CLAUDE_NO_HUD=0)
# CLAUDE_NO_HUD no está seteado aquí → HUD activo en este panel
# Los teammates se spawnean en panes nuevos donde seteamos CLAUDE_NO_HUD=1
tmux set-environment -t "$session" CLAUDE_NO_HUD "1"
tmux send-keys -t "$pane" 'export CLAUDE_NO_HUD=0 && TMPDIR=~/.cache/tmp claude --teammate-mode tmux --dangerously-skip-permissions --effort max' Enter

# Esperar a que Claude esté listo, luego enviar prompt del team
# y después redimensionar el panel principal
(
    sleep 8
    tmux send-keys -t "$pane" "$TEAM_PROMPT" Enter

    # Esperar a que se creen los teammates, luego resize
    sleep 30
    tmux select-pane -t "$session:0.0"
    tmux resize-pane -t "$session:0.0" -x '75%'
) &

exec tmux attach-session -t "$session"
