{
  "general": {
    "sessionRetention": {
      "enabled": true,
      "maxAge": "30d",
      "warningAcknowledged": true
    }
  },
  "security": {
    "auth": {
      "selectedType": "oauth-personal"
    },
    "enablePermanentToolApproval": true
  },
  "output": {
    "format": "text"
  },
  "experimental": {
    "plan": true
  },
  "mcpServers": {
    "magic": {
      "command": "npx",
      "args": ["-y", "@21st-dev/magic@latest"],
      "env": {
        "API_KEY": "API_KEY_AQUI"
      }
    },
    "figma": {
      "command": "npx",
      "args": ["-y", "figma-developer-mcp@latest"],
      "env": {
        "FIGMA_PERSONAL_ACCESS_TOKEN": "TOKEN_AQUI"
      }
    }
  }
}
